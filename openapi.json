    "/changes": {
      "get": {
        "summary": "Changes",
        "description": "Pull replication: returns the derived state for the read replicas.\n\nEntities are returned in full (they mutate); notes/facts can be filtered by\n`since` (created_at). The graph is small, so a full pull is fine for v1.\n`cursor` is the timestamp to pass as `since` next time.",
        "operationId": "changes_changes_get",
        "parameters": [
          {
            "name": "since",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
