    "/entity/{entity_id}/similar": {
      "get": {
        "summary": "Entity Similar",
        "description": "SYN-62: soft semantic neighbours of an entity — links the user never\nstated explicitly ('Escalade' ↔ 'Bouldering', 'Schopenhauer' ↔ 'Nietzsche').\n\nSuggestion only, never a materialized relation: each call recomputes against\nthe current graph (no cache — fastembed is local and the scan is sub-ms), so\nresults evolve as new entities/summaries appear. `same_type=true` restricts\nto the entity's own type. Soft-merged entities are excluded by the search.",
        "operationId": "entity_similar_entity__entity_id__similar_get",
        "parameters": [
          {
            "name": "entity_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Entity Id"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 5,
              "title": "Limit"
            }
          },
          {
            "name": "min_score",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 0.7,
              "title": "Min Score"
            }
          },
          {
            "name": "same_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "Same Type"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
