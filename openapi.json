    "/project-entries/{entry_id}/attach-to-project": {
      "post": {
        "summary": "Attach Entry To Project",
        "description": "Add a parallel rattachement to another project (additive, not move).\n\nSYN-55 + SYN-57: a capture can belong to N projects (the schema already\nallows multiple project_entries per capture_id, and the classifier emits\nproject_entries in batch). This manual endpoint mirrors that capability\nfor the UI: it takes an existing entry as a template and INSERTs a new\nrow pointing to the target project, keeping the source row intact. The\nimmutable inbox row is never touched.",
        "operationId": "attach_entry_to_project_project_entries__entry_id__attach_to_project_post",
        "parameters": [
          {
            "name": "entry_id",
            "in": "path",
            "required": true,
            "schema": {
